generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  invited
  active
  suspended
}

enum UserRole {
  owner
  manager
  cashier
  inventory_staff
}

enum BusinessType {
  retail_store
  grocery
  clothing
  pharmacy
  convenience
  online_seller
  wholesale
  service_with_products
}

enum TaxMode {
  no_tax
  inclusive_tax
  exclusive_tax
}

enum SaleStatus {
  draft
  pending_payment
  completed
  cancelled
  refunded_partially
  refunded_fully
  exception_required
}

enum PaymentMethod {
  cash
  debit_card
  credit_card
  mobile_payment
  bank_transfer
  gift_card
  store_credit
}

enum PaymentProvider {
  stripe
  square
  manual
}

enum PaymentStatus {
  pending
  authorized
  captured
  settled
  failed
  voided
  refunded_partial
  refunded_full
}

enum InventoryMovementType {
  purchase_receive
  sale_commit
  sale_void
  refund_restock
  refund_no_restock
  manual_adjustment_increase
  manual_adjustment_decrease
  stock_count_reconciliation
  transfer_in
  transfer_out
  reservation_hold
  reservation_release
}

enum RefundStatus {
  pending
  completed
  failed
  cancelled
}

enum RestockAction {
  restock_to_sellable
  restock_to_damaged
  do_not_restock
}

enum PurchaseOrderStatus {
  draft
  ordered
  partially_received
  received
  cancelled
}

model User {
  id               String             @id @default(cuid())
  businessId       String?
  fullName         String
  email            String             @unique
  passwordHash     String?
  status           UserStatus         @default(invited)
  role             UserRole
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  lastLoginAt      DateTime?
  business         Business?          @relation(fields: [businessId], references: [id], onDelete: SetNull)
  ownedBusinesses  Business[]         @relation("BusinessOwner")
  sessions         Session[]
  passwordResetTokens PasswordResetToken[]
  invitesSent      StaffInviteToken[] @relation("InviteSender")
  auditLogs        AuditLog[]
  cashSales        Sale[]             @relation("SaleCashier")
  createdRefunds   Refund[]
  movements        InventoryMovement[] @relation("InventoryMovementActor")
}

model Session {
  id                 String   @id @default(cuid())
  userId             String
  deviceName         String
  ipAddressLastSeen  String?
  userAgentLastSeen  String?
  refreshTokenHash   String
  createdAt          DateTime @default(now())
  expiresAt          DateTime
  revokedAt          DateTime?
  lastSeenAt         DateTime?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StaffInviteToken {
  id              String    @id @default(cuid())
  businessId      String
  email           String
  role            UserRole
  tokenHash       String    @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  revokedAt       DateTime?
  invitedByUserId String
  createdAt       DateTime  @default(now())
  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy       User      @relation("InviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@index([businessId, email])
}

model Business {
  id                         String            @id @default(cuid())
  ownerId                    String
  businessName               String
  businessType               BusinessType
  primaryCountry             String
  timezone                   String
  currency                   String
  taxMode                    TaxMode
  reservationDurationMinutes Int               @default(10)
  weekStartsOn               Int               @default(1)
  isActive                   Boolean           @default(true)
  nextReceiptNumber          Int               @default(1)
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  owner                      User              @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  users                      User[]
  locations                  Location[]
  taxRates                   TaxRate[]
  staffInviteTokens          StaffInviteToken[]
  suppliers                  Supplier[]
  products                   Product[]
  sales                      Sale[]
  refunds                    Refund[]
  purchaseOrders             PurchaseOrder[]
  auditLogs                  AuditLog[]
  idempotencyKeys            IdempotencyKey[]
}

model Location {
  id              String             @id @default(cuid())
  businessId      String
  name            String
  addressLine1    String
  addressLine2    String?
  city            String
  provinceOrState String
  postalCode      String
  country         String
  timezone        String?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  business        Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  sales           Sale[]
  purchaseOrders  PurchaseOrder[]

  @@index([businessId])
}

model TaxRate {
  id                  String   @id @default(cuid())
  businessId          String
  name                String
  ratePercent         Decimal  @db.Decimal(8, 4)
  appliesToCategories Json?
  compoundOrder       Int?
  isInclusive         Boolean  @default(false)
  isDefault           Boolean  @default(false)
  createdAt           DateTime @default(now())
  business            Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Supplier {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  contactName String?
  email       String?
  phone       String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  products    Product[]
  purchaseOrders PurchaseOrder[]

  @@index([businessId])
}

model Product {
  id             String    @id @default(cuid())
  businessId     String
  name           String
  category       String
  sku            String
  barcode        String?
  supplierId     String?
  unitType       String
  purchasePrice  Decimal   @db.Decimal(12, 2)
  sellingPrice   Decimal   @db.Decimal(12, 2)
  taxCategory    String?
  parLevel       Decimal   @db.Decimal(12, 3)
  allowOversell  Boolean   @default(false)
  isArchived     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier       Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  saleItems      SaleItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([businessId, sku])
  @@index([businessId, category])
}

model InventoryBalance {
  productId         String
  locationId        String
  onHandQuantity    Decimal   @db.Decimal(12, 3)
  reservedQuantity  Decimal   @db.Decimal(12, 3)
  availableQuantity Decimal   @db.Decimal(12, 3)
  versionNumber     Int       @default(1)
  updatedAt         DateTime  @updatedAt
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  location          Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([productId, locationId])
}

model InventoryMovement {
  id           String                @id @default(cuid())
  productId    String
  locationId   String
  movementType InventoryMovementType
  quantityDelta Decimal             @db.Decimal(12, 3)
  referenceType String
  referenceId   String
  reason       String
  createdById  String?
  createdAt    DateTime             @default(now())
  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  location     Location             @relation(fields: [locationId], references: [id], onDelete: Cascade)
  createdBy    User?                @relation("InventoryMovementActor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([productId, locationId, createdAt])
}

model Sale {
  id                    String       @id @default(cuid())
  businessId            String
  locationId            String
  cashierUserId         String
  status                SaleStatus
  subtotalAmount        Decimal      @db.Decimal(12, 2)
  discountAmount        Decimal      @db.Decimal(12, 2)
  taxAmount             Decimal      @db.Decimal(12, 2)
  totalAmount           Decimal      @db.Decimal(12, 2)
  amountPaid            Decimal      @db.Decimal(12, 2) @default(0)
  amountDue             Decimal      @db.Decimal(12, 2)
  completedAt           DateTime?
  businessTimezoneDate  DateTime?
  receiptNumber         String?
  saleDiscountType      String?
  saleDiscountValue     Decimal?     @db.Decimal(12, 2)
  saleDiscountReason    String?
  reservationExpiresAt  DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  business              Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location              Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  cashier               User         @relation("SaleCashier", fields: [cashierUserId], references: [id], onDelete: Restrict)
  items                 SaleItem[]
  payments              Payment[]
  refunds               Refund[]

  @@index([businessId, status, completedAt])
  @@unique([businessId, receiptNumber])
}

model SaleItem {
  id                       String   @id @default(cuid())
  saleId                   String
  productId                String
  quantity                 Decimal  @db.Decimal(12, 3)
  unitPrice                Decimal  @db.Decimal(12, 2)
  subtotal                 Decimal  @db.Decimal(12, 2)
  lineDiscountAmount       Decimal  @db.Decimal(12, 2)
  allocatedSaleDiscountAmount Decimal @db.Decimal(12, 2) @default(0)
  taxAmount                Decimal  @db.Decimal(12, 2)
  taxComponents            Json
  lineTotal                Decimal  @db.Decimal(12, 2)
  sale                     Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product                  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  refundItems              RefundItem[]

  @@index([saleId])
}

model Payment {
  id                String          @id @default(cuid())
  saleId            String
  method            PaymentMethod
  provider          PaymentProvider?
  amount            Decimal         @db.Decimal(12, 2)
  status            PaymentStatus
  externalReference String?
  receivedAt        DateTime        @default(now())
  failureReason     String?
  sale              Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  refundPayments    RefundPayment[]

  @@index([saleId, status])
}

model Refund {
  id                String       @id @default(cuid())
  businessId        String
  saleId            String
  createdById       String
  status            RefundStatus
  refundTotalAmount Decimal      @db.Decimal(12, 2)
  reasonCode        String
  note              String
  createdAt         DateTime     @default(now())
  business          Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sale              Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy         User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items             RefundItem[]
  refundPayments    RefundPayment[]

  @@index([businessId, createdAt])
}

model RefundItem {
  id               String        @id @default(cuid())
  refundId         String
  saleItemId       String
  quantityRefunded Decimal       @db.Decimal(12, 3)
  amountRefunded   Decimal       @db.Decimal(12, 2)
  restockAction    RestockAction
  refund           Refund        @relation(fields: [refundId], references: [id], onDelete: Cascade)
  saleItem         SaleItem      @relation(fields: [saleItemId], references: [id], onDelete: Restrict)

  @@index([refundId])
}

model RefundPayment {
  id             String   @id @default(cuid())
  refundId       String
  paymentId      String
  amountReversed Decimal  @db.Decimal(12, 2)
  refund         Refund   @relation(fields: [refundId], references: [id], onDelete: Cascade)
  payment        Payment  @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([refundId, paymentId])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  businessId  String
  supplierId  String
  locationId  String
  status      PurchaseOrderStatus @default(draft)
  totalCost   Decimal             @db.Decimal(12, 2)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplier    Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  location    Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  items       PurchaseOrderItem[]

  @@index([businessId, status])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String
  orderedQuantity  Decimal       @db.Decimal(12, 3)
  receivedQuantity Decimal       @db.Decimal(12, 3) @default(0)
  unitCost         Decimal       @db.Decimal(12, 2)
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product          Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
}

model AuditLog {
  id          String   @id @default(cuid())
  businessId  String
  actorUserId String?
  action      String
  resourceType String
  resourceId  String
  metadata    Json
  ipAddress   String?
  createdAt   DateTime @default(now())
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  businessId   String
  key          String
  operation    String
  resourceType String
  resourceId   String
  createdAt    DateTime @default(now())
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, operation, key])
}

model AuthThrottle {
  id           String   @id @default(cuid())
  email        String
  ipAddress    String?
  failedCount  Int      @default(0)
  blockedUntil DateTime?
  lastFailedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([email, ipAddress])
}
