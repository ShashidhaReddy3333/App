{
  "name": "business-management-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.11.1",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/clean-next.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "env:check": "tsx scripts/check-runtime.ts",
    "db:health": "tsx scripts/check-db.ts",
    "ops:cleanup-reservations": "tsx scripts/release-expired-reservations.ts",
    "ops:check-data": "tsx scripts/check-data-integrity.ts",
    "ops:cleanup-maintenance": "tsx scripts/cleanup-operational-data.ts",
    "notifications:process": "tsx scripts/process-notifications.ts",
    "monitoring:test": "tsx scripts/send-monitoring-test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "pnpm prisma:migrate:dev",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:reset": "prisma migrate reset --force --skip-generate --skip-seed",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "demo:setup": "pnpm db:health && pnpm prisma:generate && pnpm prisma:reset && pnpm prisma:seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@hookform/resolvers": "^4.1.0",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@tanstack/react-table": "^8.21.2",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.0.10",
    "lucide-react": "^0.511.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.3.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.51.1",
    "postcss": "^8.5.3",
    "prisma": "^6.6.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
